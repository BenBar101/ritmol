# ── RITMOL environment variables ────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Dropbox OAuth App Key (public-client PKCE — safe to expose in bundle).
# Create a Scoped app at https://www.dropbox.com/developers/apps
# Required scopes: files.content.read, files.content.write
# Add your production origin to Redirect URIs in the Dropbox app console.
#
# SECURITY NOTE: Vite inlines this value into the compiled JS bundle via
# import.meta.env replacement. It is visible to any user who inspects the
# Network tab or deobfuscates the bundle. This is expected for public-client
# OAuth; the PKCE code_verifier (stored in sessionStorage) is the real secret.
# Rotate the key immediately if it appears in a public repository or HAR export.
VITE_DROPBOX_APP_KEY=your_dropbox_app_key_here

# Base path for deployment (e.g. /ritmol for GitHub Pages at org.github.io/ritmol).
# Leave empty or set to / for root deployments (Vercel, Netlify, custom domain).
VITE_BASE_PATH=/
