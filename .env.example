# Optional. The deployed site gets config from GitHub repo Variables
# (Settings → Secrets and variables → Actions → Variables).
# Use this file to test single-account gate locally. Copy to .env and fill in; .env is in .gitignore.
#
# For local dev without the gate, leave VITE_ALLOWED_EMAIL and VITE_GOOGLE_CLIENT_ID empty.

# Base path for GitHub Pages (e.g. repo "jarvis" -> https://user.github.io/jarvis/)
# Use a leading and trailing slash: /your-repo-name/
VITE_BASE_PATH=/

# Single-account access: only this Google email can use the app (case-insensitive).
# Example (use a dummy in docs; use your real email in real config): allowed@example.com
# Leave empty to disable the gate.
VITE_ALLOWED_EMAIL=

# Google OAuth Client ID for the sign-in gate (same as Calendar or a separate Web app).
# Required when VITE_ALLOWED_EMAIL is set. Add your GitHub Pages URL to Authorized JavaScript origins.
VITE_GOOGLE_CLIENT_ID=

# Optional: URL of your JWT verification endpoint (e.g. Vercel serverless api/verify-google-id).
# When set, the client sends the Google ID token here for signature verification instead of decoding in the browser.
# VITE_VERIFY_GOOGLE_ID_URL=

# Required: Gemini API key (Google AI Studio). Set in GitHub repo Variables or .env. The app does not accept the key in the UI.
VITE_GEMINI_API_KEY=

# Required: Dropbox App Key for sync (from dropbox.com/developers/apps). Set in GitHub repo Variables or .env. The app does not accept the key in the UI.
VITE_DROPBOX_APP_KEY=
